      "id": "invertebrates",
      "title": "Invertebrates",
      "emoji": "🐛",
      "topics": [
        {
          "id": "arthropods",
          "name": "Arthropods",
          "emoji": "🦗",
          "definition": "They have an <strong>EXOSKELETON</strong>, a <strong>SEGMENTED BODY</strong>, and legs.",
          "extra": "There are 4 groups: <em>insects</em>, <em>arachnids</em>, <em>crustaceans</em>, <em>myriapods</em>.",
          "keyWords": ["EXOSKELETON", "SEGMENTED BODY"]
        },
        {
          "id": "molluscs",
          "name": "Molluscs",
          "emoji": "🐌",
          "definition": "They have a <strong>SOFT BODY</strong>. They can live on <strong>LAND</strong> or in <strong>WATER</strong>. They usually have a <strong>SHELL</strong>.",
          "extra": "There are 3 groups: <em>gastropods</em> (snails), <em>cephalopods</em> (octopus), <em>bivalves</em> (oysters, mussels).",
          "keyWords": ["SOFT BODY", "LAND", "WATER", "SHELL"]
        },
        {
          "id": "annelids",
          "name": "Annelids",
          "emoji": "🪱",
          "definition": "They have a <strong>LONG SOFT BODY</strong> with <strong>RINGS</strong>. They can live on <strong>LAND</strong> or in <strong>WATER</strong>.",
          "extra": "Examples: <em>earthworms</em>, <em>leeches</em>.",
          "keyWords": ["LONG SOFT BODY", "RINGS", "LAND", "WATER"]
        },
        {
          "id": "echinoderms",
          "name": "Echinoderms",
          "emoji": "⭐",
          "definition": "They have a <strong>HARD SKIN</strong> or <strong>SPINES</strong>. They live in <strong>WATER</strong>. They have <strong>RADIAL SYMMETRY</strong>.",
          "extra": "Examples: <em>sea urchin</em>, <em>starfish</em>.",
          "keyWords": ["HARD SKIN", "SPINES", "WATER", "RADIAL SYMMETRY"]
        },
        {
          "id": "cnidarians",
          "name": "Cnidarians",
          "emoji": "🪼",
          "definition": "They have <strong>JELLY-LIKE BODIES</strong> that look like umbrellas. They live in <strong>WATER</strong> and move about in sea currents. They have <strong>POISONOUS TENTACLES</strong>.",
          "extra": "Examples: <em>anemones</em>, <em>jellyfish</em>.",
          "keyWords": ["JELLY-LIKE BODIES", "WATER", "POISONOUS TENTACLES"]
        },
        {
          "id": "poriferans",
          "name": "Poriferans",
          "emoji": "🧽",
          "definition": "They are <strong>VERY SIMPLE</strong>. They are aquatic and live <strong>ATTACHED TO ROCKS</strong>. They <strong>CANNOT MOVE</strong>.",
          "extra": "There are many different shapes and colours.",
          "keyWords": ["VERY SIMPLE", "ATTACHED TO ROCKS", "CANNOT MOVE"]
        }
      ],
