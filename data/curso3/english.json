            { "subject": "We", "verb": "have to", "example": "do our homework" },
            { "subject": "You (plural)", "verb": "have to", "example": "be quiet" },
            { "subject": "They", "verb": "have to", "example": "follow the rules" }
          ],
          "negative": [
            { "subject": "I", "verb": "do not have to", "example": "work on Sundays" },
            { "subject": "You", "verb": "do not have to", "example": "come early" },
            { "subject": "He / She / It", "verb": "does not have to", "example": "wear a tie" },
            { "subject": "We", "verb": "do not have to", "example": "pay now" },
            { "subject": "You (plural)", "verb": "do not have to", "example": "hurry" },
            { "subject": "They", "verb": "do not have to", "example": "leave yet" }
          ],
          "extra": "Contractions: do not → don't · does not → doesn't · Negative means NO OBLIGATION — it is not necessary, but it is allowed."
        },
